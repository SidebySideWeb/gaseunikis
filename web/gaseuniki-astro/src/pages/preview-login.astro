---
export const prerender = false;

import '../styles/global.css';
import { isPreviewAuthEnabled, safeReturnPath } from '../lib/preview-auth';

if (!isPreviewAuthEnabled()) {
  return Astro.redirect('/');
}

const returnPath = safeReturnPath(Astro.url.searchParams.get('return'));
const hasError = Astro.url.searchParams.get('error') === '1';
---

<!doctype html>
<html lang="el">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Πρόσβαση Preview | ΓΑΣ Ευνίκη</title>
    <link rel="icon" type="image/png" href="/favicon.png" />
  </head>
  <body class="min-h-screen bg-background px-gutter py-16 text-on-surface">
    <main class="mx-auto w-full max-w-md rounded-3xl border border-outline-variant/30 bg-white p-8 shadow-card">
      <h1 class="font-display text-headline-lg text-primary mb-2">Πρόσβαση Preview</h1>
      <p class="text-on-surface-variant mb-8">
        Ο ιστότοπος είναι προσωρινά κλειδωμένος. Συνδεθείτε για να συνεχίσετε.
      </p>

      {
        hasError && (
          <p class="mb-6 rounded-xl border border-error/20 bg-error-container px-4 py-3 text-on-error-container" role="alert">
            Λάθος όνομα χρήστη ή κωδικός. Δοκιμάστε ξανά.
          </p>
        )
      }

      <form method="POST" action="/api/preview-auth" class="space-y-5">
        <input type="hidden" name="return" value={returnPath} />

        <div class="space-y-2">
          <label class="font-label-md text-on-surface-variant" for="username">Όνομα χρήστη</label>
          <input
            id="username"
            name="username"
            type="text"
            required
            autocomplete="username"
            class="w-full rounded-xl border border-outline-variant bg-surface-container-low px-5 py-4 outline-none focus:border-primary focus:ring-2 focus:ring-primary"
          />
        </div>

        <div class="space-y-2">
          <label class="font-label-md text-on-surface-variant" for="password">Κωδικός</label>
          <input
            id="password"
            name="password"
            type="password"
            required
            autocomplete="current-password"
            class="w-full rounded-xl border border-outline-variant bg-surface-container-low px-5 py-4 outline-none focus:border-primary focus:ring-2 focus:ring-primary"
          />
        </div>

        <button
          type="submit"
          class="w-full rounded-xl bg-primary py-4 font-display text-label-md text-on-primary shadow-card transition-colors hover:bg-primary-light"
        >
          Σύνδεση
        </button>
      </form>
    </main>
  </body>
</html>
