---
import Layout from '../layouts/Layout.astro';
import HomeHero from '../components/home/HomeHero.astro';
import HomeAbout from '../components/home/HomeAbout.astro';
import HomeSections from '../components/home/HomeSections.astro';
import HomeGallery from '../components/home/HomeGallery.astro';
import HomeSuccesses from '../components/home/HomeSuccesses.astro';
import HomeNews from '../components/home/HomeNews.astro';
import HomeWhy from '../components/home/HomeWhy.astro';
import HomeCTA from '../components/home/HomeCTA.astro';
import { getHomePage, getLatestNews } from '../lib/queries';
import {
  defaultHomePage,
  defaultGalleryItems,
  defaultFeaturedSuccesses,
  defaultLatestNews,
} from '../lib/fallbacks';
import type { HomePage, Achievement, NewsItem } from '../lib/types';

let homePage: HomePage | null = null;
let latestNews: NewsItem[] = [];

try {
  [homePage, latestNews] = await Promise.all([getHomePage(), getLatestNews()]);
} catch {
  /* fall back to defaults */
}

const home = { ...defaultHomePage, ...homePage };
const galleryItems = home.galleryImages?.length ? home.galleryImages : defaultGalleryItems;
const successes = home.featuredSuccesses?.length ? home.featuredSuccesses : defaultFeaturedSuccesses;
const news = latestNews.length ? latestNews : defaultLatestNews;
const stats = home.stats?.length ? home.stats : defaultHomePage.stats!;

const pageTitle = home.seo?.title ?? 'ΓΑΣ Ευνίκη Ελευσίνας';
const pageDescription =
  home.seo?.description ??
  'Αθλητικός σύλλογος ρυθμικής γυμναστικής και γυμναστικής για Όλους στην Ελευσίνα. Τμήματα για ηλικίες 3-18 ετών. Εγγραφές 2024-2025.';
---

<Layout title={pageTitle} description={pageDescription} currentPath="/" noIndex={home.seo?.noIndex}>
  <HomeHero
    badge={home.heroBadge!}
    heading={home.heroHeading!}
    subheading={home.heroSubheading!}
    quote={home.heroQuote!}
    primaryCtaLabel={home.heroPrimaryCtaLabel!}
    primaryCtaUrl={home.heroPrimaryCtaUrl!}
    secondaryCtaLabel={home.heroSecondaryCtaLabel!}
    secondaryCtaUrl={home.heroSecondaryCtaUrl!}
  />
  <HomeAbout
    heading={home.aboutHeading!}
    text={home.aboutText!}
    accreditedBy={home.aboutAccreditedBy!}
    yearsExperience={home.yearsExperience!}
  />
  <HomeSections heading={home.sectionsHeading!} />
  <HomeGallery heading={home.galleryHeading!} items={galleryItems} />
  <HomeSuccesses
    heading={home.successesHeading!}
    subheading={home.successesSubheading!}
    items={successes as Achievement[]}
    stats={stats}
    ctaLabel={home.successesCtaLabel!}
    ctaUrl={home.successesCtaUrl!}
  />
  <HomeNews
    heading={home.newsHeading!}
    ctaLabel={home.newsCtaLabel!}
    ctaUrl={home.newsCtaUrl!}
    posts={news}
  />
  <HomeWhy
    heading={home.whyHeading!}
    items={home.whyItems ?? defaultHomePage.whyItems!}
    sponsorsHeading={home.sponsorsHeading!}
  />
  <HomeCTA
    heading={home.ctaHeading!}
    text={home.ctaText!}
    buttonLabel={home.ctaButtonLabel!}
    buttonUrl={home.ctaButtonUrl!}
  />
</Layout>
