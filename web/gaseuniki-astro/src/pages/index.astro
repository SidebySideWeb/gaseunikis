---
import { shouldPrerenderForPreviewAuth } from '../lib/preview-auth';

export const prerender = shouldPrerenderForPreviewAuth();

import Layout from '../layouts/Layout.astro';
import HomeHero from '../components/home/HomeHero.astro';
import HomeAbout from '../components/home/HomeAbout.astro';
import HomeSections from '../components/home/HomeSections.astro';
import HomeGallery from '../components/home/HomeGallery.astro';
import HomeSuccessesIsland from '../components/home/HomeSuccessesIsland.astro';
import HomeSuccessesFallback from '../components/home/HomeSuccessesFallback.astro';
import HomeNewsIsland from '../components/home/HomeNewsIsland.astro';
import HomeNewsFallback from '../components/home/HomeNewsFallback.astro';
import HomeWhy from '../components/home/HomeWhy.astro';
import HomeCTA from '../components/home/HomeCTA.astro';
import { getHomepageStaticBundle } from '../lib/queries';
import { fetchWithFallback } from '../lib/fetch-with-fallback';
import { resolvePresetImage } from '../lib/image';
import {
  defaultHomePage,
  defaultGalleryItems,
  defaultSectionsPreview,
  defaultSiteSettings,
} from '../lib/fallbacks';
import { stitchImages } from '../lib/stitch-images';

const emptyBundle = {
  homePage: null,
  sectionsPage: null,
  siteSettings: null,
};

const bundle = await fetchWithFallback(
  () => getHomepageStaticBundle(),
  emptyBundle,
  'homepageStaticBundle',
);
const siteSettings = { ...defaultSiteSettings, ...bundle.siteSettings };

const homePage = bundle.homePage;
const sectionsPage = bundle.sectionsPage;

const home = { ...defaultHomePage, ...homePage };
const sections = { ...defaultSectionsPreview, ...sectionsPage };
const galleryItems = home.galleryImages?.length ? home.galleryImages : defaultGalleryItems;
const stats = home.stats?.length ? home.stats : defaultHomePage.stats!;
const sponsors = home.sponsors?.length ? home.sponsors : defaultHomePage.sponsors!;

const heroImage = resolvePresetImage(home.heroImage, stitchImages.hero, 'hero');
const aboutImage = resolvePresetImage(home.aboutImage, stitchImages.aboutCoach, 'halfWidth');
const whyImage = resolvePresetImage(home.whyImage, stitchImages.whyUs, 'halfWidth');

const pageTitle = home.seo?.title ?? 'ΓΑΣ Ευνίκη Ελευσίνας';
const pageDescription =
  home.seo?.description ??
  'Αθλητικός σύλλογος ρυθμικής γυμναστικής και γυμναστικής για Όλους στην Ελευσίνα. Τμήματα για ηλικίες 3-18 ετών. Εγγραφές 2024-2025.';
---

<Layout
  title={pageTitle}
  description={pageDescription}
  currentPath="/"
  noIndex={home.seo?.noIndex}
  settings={siteSettings}
  lcpImage={heroImage}
>
  <HomeHero
    badge={home.heroBadge!}
    heading={home.heroHeading!}
    subheading={home.heroSubheading!}
    quote={home.heroQuote!}
    primaryCtaLabel={home.heroPrimaryCtaLabel!}
    primaryCtaUrl={home.heroPrimaryCtaUrl!}
    secondaryCtaLabel={home.heroSecondaryCtaLabel!}
    secondaryCtaUrl={home.heroSecondaryCtaUrl!}
    image={heroImage}
    imageAlt={home.heroImage?.alt}
  />
  <HomeAbout
    heading={home.aboutHeading!}
    text={home.aboutText!}
    secondParagraph={home.aboutSecondParagraph!}
    yearsExperience={home.yearsExperience!}
    image={aboutImage}
    imageAlt={home.aboutImage?.alt}
  />
  <HomeSections
    heading={home.sectionsHeading!}
    ctaLabel={home.sectionsCtaLabel!}
    ctaUrl={home.sectionsCtaUrl!}
    rhythmicHeading={sections.rhythmicHeading!}
    rhythmicDescription={sections.rhythmicDescription!}
    rhythmicCategoryHeading={sections.rhythmicCategoryHeading!}
    rhythmicCompetitive={sections.rhythmicCompetitive?.length ? sections.rhythmicCompetitive : defaultSectionsPreview.rhythmicCompetitive!}
    rhythmicMassHeading={sections.rhythmicMassHeading!}
    rhythmicMass={sections.rhythmicMass?.length ? sections.rhythmicMass : defaultSectionsPreview.rhythmicMass!}
    gymnHeading={sections.gymnHeading!}
    gymnDescription={sections.gymnDescription!}
    gymSections={sections.gymSections?.length ? sections.gymSections : defaultSectionsPreview.gymSections!}
  />
  <HomeGallery
    heading={home.galleryHeading!}
    subheading={home.gallerySubheading!}
    items={galleryItems}
  />
  <HomeSuccessesIsland
    server:defer
    heading={home.successesHeading!}
    subheading={home.successesSubheading!}
    stats={stats}
    ctaLabel={home.successesCtaLabel!}
    ctaUrl={home.successesCtaUrl!}
  >
    <HomeSuccessesFallback
      slot="fallback"
      heading={home.successesHeading!}
      subheading={home.successesSubheading!}
      stats={stats}
      ctaLabel={home.successesCtaLabel!}
      ctaUrl={home.successesCtaUrl!}
    />
  </HomeSuccessesIsland>
  <HomeNewsIsland
    server:defer
    heading={home.newsHeading!}
    ctaLabel={home.newsCtaLabel!}
    ctaUrl={home.newsCtaUrl!}
  >
    <HomeNewsFallback
      slot="fallback"
      heading={home.newsHeading!}
      ctaLabel={home.newsCtaLabel!}
      ctaUrl={home.newsCtaUrl!}
    />
  </HomeNewsIsland>
  <HomeWhy
    heading={home.whyHeading!}
    items={home.whyItems ?? defaultHomePage.whyItems!}
    sponsorsHeading={home.sponsorsHeading!}
    sponsors={sponsors}
    image={whyImage}
    imageAlt={home.whyImage?.alt}
  />
  <HomeCTA
    heading={home.ctaHeading!}
    text={home.ctaText!}
    buttonLabel={home.ctaButtonLabel!}
    buttonUrl={home.ctaButtonUrl!}
  />
</Layout>
