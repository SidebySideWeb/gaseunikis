---
import { shouldPrerenderForPreviewAuth } from '../../lib/preview-auth';

export const prerender = shouldPrerenderForPreviewAuth();

import Layout from '../../layouts/Layout.astro';
import BreadcrumbSchema from '../../components/schema/BreadcrumbSchema.astro';
import ContentPageArticle from '../../components/content/ContentPageArticle.astro';
import { client } from '../../lib/sanity';
import { contentPageBySlugQuery, contentPageSlugsQuery } from '../../lib/queries';
import type { ContentPage } from '../../lib/types';

export async function getStaticPaths() {
  let slugs: { slug: string }[] = [];

  try {
    slugs = await client.fetch<{ slug: string }[]>(contentPageSlugsQuery);
  } catch {
    return [];
  }

  const paths = await Promise.all(
    slugs.map(async ({ slug }) => {
      try {
        const page = await client.fetch<ContentPage | null>(contentPageBySlugQuery, { slug });
        if (!page?.title) {
          return null;
        }
        return { params: { slug }, props: { page } };
      } catch {
        return null;
      }
    }),
  );

  return paths.filter((path): path is NonNullable<typeof path> => path !== null);
}

const { slug } = Astro.params;
let page: ContentPage | null = Astro.props.page ?? null;

if (!page && slug) {
  page = await client.fetch<ContentPage | null>(contentPageBySlugQuery, { slug });
}

if (!page?.title) {
  return Astro.redirect('/404');
}

const currentPath = `/selida/${slug}`;
const pageTitle = page.seo?.title ?? page.title ?? 'Σελίδα';
const pageDescription =
  page.seo?.description ?? page.intro ?? `${page.title} — ΓΑΣ Ευνίκη Ελευσίνας.`;
---

<Layout
  title={pageTitle}
  description={pageDescription}
  currentPath={currentPath}
  noIndex={page.seo?.noIndex}
>
  <BreadcrumbSchema
    slot="schema"
    items={[
      { name: 'Αρχική', url: '/' },
      { name: page.title ?? 'Σελίδα', url: currentPath },
    ]}
  />
  <main class="pt-32 pb-section-padding px-gutter">
    <ContentPageArticle page={page} />
  </main>
</Layout>
