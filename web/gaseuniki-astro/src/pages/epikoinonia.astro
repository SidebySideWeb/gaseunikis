---
export const prerender = true;

import Layout from '../layouts/Layout.astro';
import BreadcrumbSchema from '../components/schema/BreadcrumbSchema.astro';
import ContactHero from '../components/contact/ContactHero.astro';
import ContactInfo from '../components/contact/ContactInfo.astro';
import ContactForm from '../components/contact/ContactForm.astro';
import ContactMap from '../components/contact/ContactMap.astro';
import { getContactPage, getSiteSettings } from '../lib/queries';
import { fetchWithFallback } from '../lib/fetch-with-fallback';
import { defaultSiteSettings, defaultSubjectOptions } from '../lib/fallbacks';
import type { ContactPage } from '../lib/types';

const defaultPage: ContactPage = {
  heroHeading: 'Επικοινωνία',
  heroText:
    'Είμαστε πάντα στη διάθεσή σας για οποιαδήποτε πληροφορία σχετικά με τα προγράμματα και τις εγγραφές του συλλόγου μας.',
  heroCallToAction: 'Ελάτε σε Επαφή',
  formHeading: 'Στείλτε μας μήνυμα',
  formSubmitLabel: 'Αποστολή Μηνύματος',
  privacyCheckboxLabel:
    'Αποδέχομαι την επεξεργασία των δεδομένων μου για τους σκοπούς της επικοινωνίας σύμφωνα με την πολιτική απορρήτου του συλλόγου.',
  mapHeading: 'ΓΑΣ ΕΥΝΙΚΗ',
  mapText:
    'Βρείτε μας στην καρδιά της Ελευσίνας. Εύκολη πρόσβαση για όλους τους αθλητές μας.',
  mapButtonLabel: 'Οδηγίες Χάρτη',
};

const [fetchedPage, fetchedSettings] = await Promise.all([
  fetchWithFallback(() => getContactPage(), null, 'contactPage'),
  fetchWithFallback(() => getSiteSettings(), null, 'siteSettings'),
]);

const page = { ...defaultPage, ...fetchedPage };
const settings = { ...defaultSiteSettings, ...fetchedSettings };

const pageTitle = page.seo?.title ?? 'Επικοινωνία';
const pageDescription =
  page.seo?.description ??
  'Επικοινωνήστε με τον ΓΑΣ Ευνίκη Ελευσίνας. Διεύθυνση: Χαριλάου και Παγκάλου 5, Ελευσίνα. Τηλ: 698 444 6065.';
---

<Layout title={pageTitle} description={pageDescription} currentPath="/epikoinonia" noIndex={page.seo?.noIndex}>
  <BreadcrumbSchema
    slot="schema"
    items={[
      { name: 'Αρχική', url: '/' },
      { name: 'Επικοινωνία', url: '/epikoinonia' },
    ]}
  />
  <main class="pt-24 min-h-screen ribbon-bg flex-1">
    <ContactHero
      heading={page.heroHeading ?? ''}
      text={page.heroText ?? ''}
      callToAction={page.heroCallToAction ?? ''}
    />

    <section class="pb-section-padding px-gutter max-w-container-max-width mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-start">
        <ContactInfo
          address={settings.address ?? ''}
          phone={settings.phone ?? ''}
          email={settings.email ?? ''}
          hours={settings.openingHours ?? []}
          facebookUrl={settings.facebookUrl}
          instagramUrl={settings.instagramUrl}
        />
        <ContactForm
          formHeading={page.formHeading ?? ''}
          formSubmitLabel={page.formSubmitLabel ?? ''}
          privacyCheckboxLabel={page.privacyCheckboxLabel ?? ''}
          subjectOptions={page.subjectOptions?.length ? page.subjectOptions : defaultSubjectOptions}
        />
      </div>
    </section>

    <ContactMap
      heading={page.mapHeading ?? ''}
      text={page.mapText ?? ''}
      buttonLabel={page.mapButtonLabel ?? ''}
      address={settings.address ?? ''}
      embedUrl={settings.mapUrl}
    />
  </main>
</Layout>
