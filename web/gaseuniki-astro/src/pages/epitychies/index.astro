---
import Layout from '../../layouts/Layout.astro';
import BreadcrumbSchema from '../../components/schema/BreadcrumbSchema.astro';
import SuccessesHero from '../../components/successes/SuccessesHero.astro';
import SuccessesFilterBar from '../../components/successes/SuccessesFilterBar';
import SuccessesGrid from '../../components/successes/SuccessesGrid.astro';
import { client } from '../../lib/sanity';
import { epitychiesPageQuery, epitychiesListQuery } from '../../lib/queries';
import { buildAchievementDisplayList, getLcpAchievementImage } from '../../lib/successes-display';
import type { EpitychiesPage, Achievement } from '../../lib/types';

const defaultPage: EpitychiesPage = {
  heroHeading: 'Οι Επιτυχίες μας',
  heroLabel: 'Hall of Fame',
  heroText:
    'Κάθε μετάλλιο είναι αποτέλεσμα σκληρής δουλειάς, πειθαρχίας και αγάπης για το άθλημα. Δείτε τις διακρίσεις των αθλητριών και των ομάδων μας.',
  filterLabels: ['Όλες', 'Ρυθμική Γυμναστική', 'Γυμναστική για Όλους'],
};

const [fetchedPage, achievements] = await Promise.all([
  client.fetch<EpitychiesPage | null>(epitychiesPageQuery),
  client.fetch<Achievement[]>(epitychiesListQuery),
]);

const page = { ...defaultPage, ...fetchedPage };

const displayAchievements = buildAchievementDisplayList(achievements);
const lcpImage = getLcpAchievementImage(displayAchievements);

const pageTitle = page.seo?.title ?? 'Οι Επιτυχίες μας';
const pageDescription =
  page.seo?.description ??
  'Διακρίσεις, μετάλλια και επιτυχίες των αθλητριών και ομάδων του ΓΑΣ Ευνίκη σε πανελλήνια και διεθνή πρωταθλήματα.';
---

<Layout
  title={pageTitle}
  description={pageDescription}
  currentPath="/epitychies"
  noIndex={page.seo?.noIndex}
  lcpImage={lcpImage}
>
  <BreadcrumbSchema
    slot="schema"
    items={[
      { name: 'Αρχική', url: '/' },
      { name: 'Επιτυχίες', url: '/epitychies' },
    ]}
  />
  <main class="pt-32 pb-section-padding">
    <SuccessesHero
      heading={page.heroHeading ?? ''}
      label={page.heroLabel ?? ''}
      text={page.heroText ?? ''}
    />
    <SuccessesFilterBar client:idle filterLabels={page.filterLabels ?? defaultPage.filterLabels!} />
    <SuccessesGrid items={displayAchievements} />
  </main>
</Layout>
