---
import Layout from '../../../layouts/Layout.astro';
import BreadcrumbSchema from '../../../components/schema/BreadcrumbSchema.astro';
import NewsHero from '../../../components/news/NewsHero.astro';
import NewsGrid from '../../../components/news/NewsGrid.astro';
import NewsPagination from '../../../components/news/NewsPagination.astro';
import { client } from '../../../lib/sanity';
import {
  newsIndexPageQuery,
  newsCountQuery,
  paginatedNewsQuery,
} from '../../../lib/queries';
import {
  getNewsPageRange,
  getPostsPerPage,
  getTotalNewsPages,
} from '../../../lib/news';
import type { NewsIndexPage, NewsItem } from '../../../lib/types';

const defaultPage: NewsIndexPage = {
  heroHeading: 'Νέα & Ανακοινώσεις',
  heroText:
    'Μείνετε ενημερωμένοι για ό,τι συμβαίνει στον σύλλογό μας, από αγωνιστικές επιτυχίες μέχρι νέες εγγραφές και εκδηλώσεις.',
};

const pageNumber = Number(Astro.params.page);
const currentPage = Number.isFinite(pageNumber) && pageNumber > 1 ? pageNumber : 2;

let fetchedPage: NewsIndexPage | null = null;
let totalPosts = 0;
let posts: NewsItem[] = [];

try {
  [fetchedPage, totalPosts] = await Promise.all([
    client.fetch<NewsIndexPage | null>(newsIndexPageQuery),
    client.fetch<number>(newsCountQuery),
  ]);
} catch {
  /* fall back to defaults */
}

const page = { ...defaultPage, ...fetchedPage };
const postsPerPage = getPostsPerPage(page.postsPerPage);
const totalPages = getTotalNewsPages(totalPosts, postsPerPage);
const { start, end } = getNewsPageRange(currentPage, postsPerPage);

try {
  posts = await client.fetch<NewsItem[]>(paginatedNewsQuery, { start, end });
} catch {
  posts = [];
}

if (currentPage < 2 || currentPage > totalPages) {
  return new Response(null, { status: 404, statusText: 'Not Found' });
}

const pageTitle = page.seo?.title ?? `Νέα & Ανακοινώσεις — Σελίδα ${currentPage}`;
const pageDescription =
  page.seo?.description ??
  'Τελευταία νέα, ανακοινώσεις και εκδηλώσεις του ΓΑΣ Ευνίκη Ελευσίνας.';
---

<Layout
  title={pageTitle}
  description={pageDescription}
  currentPath={`/nea/page/${currentPage}`}
  noIndex={page.seo?.noIndex}
>
  <BreadcrumbSchema
    slot="schema"
    items={[
      { name: 'Αρχική', url: '/' },
      { name: 'Νέα', url: '/nea' },
      { name: `Σελίδα ${currentPage}`, url: `/nea/page/${currentPage}` },
    ]}
  />
  <main class="pt-32 px-gutter w-full max-w-container-max-width mx-auto">
    <NewsHero heading={page.heroHeading ?? ''} text={page.heroText ?? ''} />
    <NewsGrid items={posts ?? []} />
    <NewsPagination currentPage={currentPage} totalPages={totalPages} />
  </main>
</Layout>
