---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import SeoHead from '../components/SeoHead.astro';
import LocalBusinessSchema from '../components/schema/LocalBusinessSchema.astro';
import GtmHead from '../components/GtmHead.astro';
import GtmBody from '../components/GtmBody.astro';
import CookieConsent from '../components/CookieConsent.astro';
import { getSiteSettings } from '../lib/gaseuniki';
import { defaultSiteSettings } from '../lib/fallbacks';
import { fetchWithFallback } from '../lib/fetch-with-fallback';
import { getImageUrl, getLcpPreloadHref, IMAGE_PRESETS, type ImageDelivery } from '../lib/image';
import { buildAbsoluteUrl, resolveSiteOrigin } from '../lib/site-url';
import type { SiteSettings } from '../lib/types';
import nunitoLatin700 from '@fontsource/nunito/files/nunito-latin-700-normal.woff2?url';
import '../styles/global.css';

export interface Props {
  title: string;
  description: string;
  ogImage?: string;
  noIndex?: boolean;
  currentPath: string;
  settings?: SiteSettings | null;
  lcpImage?: ImageDelivery;
}

const {
  title,
  description,
  ogImage,
  noIndex = false,
  currentPath,
  settings: preloadedSettings,
  lcpImage,
} = Astro.props;

const siteOrigin = resolveSiteOrigin(Astro.site);
const canonicalUrl = buildAbsoluteUrl(currentPath, siteOrigin);
const gtmId = (import.meta.env.PUBLIC_GTM_ID ?? '').trim();

const fetchedSettings =
  preloadedSettings !== undefined
    ? preloadedSettings
    : await fetchWithFallback(() => getSiteSettings(), null, 'siteSettings');
const siteSettings = { ...defaultSiteSettings, ...fetchedSettings };

const defaultOgImage =
  getImageUrl(siteSettings.defaultOgImage, IMAGE_PRESETS.og) ??
  '/images/og-default.jpg';

const resolvedOgImage = ogImage ?? defaultOgImage;
const lcpPreloadHref = lcpImage ? getLcpPreloadHref(lcpImage) : undefined;
---

<!doctype html>
<html lang="el">
  <head>
    <meta charset="utf-8" />
    <CookieConsent />
    {gtmId ? <GtmHead gtmId={gtmId} /> : null}
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="preconnect" href="https://cdn.sanity.io" crossorigin />
    <link rel="preload" href={nunitoLatin700} as="font" type="font/woff2" crossorigin />
    <link
      rel="stylesheet"
      href="/styles/material-symbols.css"
      media="print"
      onload="this.media='all'"
    />
    <noscript><link rel="stylesheet" href="/styles/material-symbols.css" /></noscript>
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/favicon.png" />
    <meta name="generator" content={Astro.generator} />
    {
      lcpPreloadHref && (
        <link rel="preload" as="image" href={lcpPreloadHref} fetchpriority="high" />
      )
    }
    <SeoHead
      title={title}
      description={description}
      ogImage={resolvedOgImage}
      defaultOgImage={defaultOgImage}
      noIndex={noIndex}
      canonicalUrl={canonicalUrl}
      seoTitleSuffix={siteSettings.defaultSeoTitle ?? '| ΓΑΣ Ευνίκη Ελευσίνας'}
    />
    <LocalBusinessSchema settings={siteSettings} />
    <slot name="schema" />
  </head>
  <body class="custom-scrollbar overflow-x-hidden">
    {gtmId ? <GtmBody gtmId={gtmId} /> : null}
    <Nav currentPath={currentPath} settings={siteSettings} />
    <main class="mt-20 flex-1">
      <slot />
    </main>
    <Footer settings={siteSettings} />
  </body>
</html>
