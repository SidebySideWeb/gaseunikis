---
import PlaceholderImage from '../ui/PlaceholderImage.astro';
import type { WhyItem } from '../../lib/types';
import { stitchImages } from '../../lib/stitch-images';

interface Props {
  heading: string;
  items: WhyItem[];
  sponsorsHeading: string;
}

const { heading, items, sponsorsHeading } = Astro.props;

const sponsors = ['ΚΑΡΠΑΘΙΟΣ Development', 'AKROR Group'];
---

<section class="ribbon-bg py-section-padding">
  <div class="container-page grid items-start gap-16 md:grid-cols-2">
    <div>
      <h2 class="mb-8 font-display text-headline-lg text-on-surface">{heading}</h2>
      <ul class="space-y-6">
        {items.map((item) => (
          <li class="flex gap-4">
            <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full border border-primary/20 bg-primary/10">
              <span class="material-symbols-outlined text-primary" aria-hidden="true">{item.icon ?? 'check'}</span>
            </div>
            <div>
              <h3 class="font-display text-headline-md text-on-surface">{item.title}</h3>
              <p class="text-on-surface-variant">{item.description}</p>
            </div>
          </li>
        ))}
      </ul>
    </div>

    <PlaceholderImage
      src={stitchImages.whyUs}
      alt="Οφέλη συμμετοχής στον σύλλογο"
      class="min-h-[320px] w-full rounded-3xl border border-primary/10 object-cover shadow-card"
    />
  </div>
</section>

<section class="border-y border-primary/5 bg-surface-container py-16">
  <div class="container-page">
    <p class="mb-10 text-center font-display text-label-md uppercase tracking-widest text-primary">{sponsorsHeading}</p>
    <div class="flex flex-wrap items-center justify-center gap-16 opacity-60 grayscale transition-all hover:opacity-100 hover:grayscale-0">
      {sponsors.map((name) => (
        <span class="font-display text-2xl font-bold text-on-surface">{name}</span>
      ))}
      <span class="flex h-12 w-32 items-center justify-center rounded-lg border border-on-surface/5 bg-surface-container italic text-on-surface-variant">
        Sponsor Logo
      </span>
    </div>
  </div>
</section>
