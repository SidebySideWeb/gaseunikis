---
import PlaceholderImage from '../ui/PlaceholderImage.astro';
import Button from '../ui/Button.astro';
import type { ImageDelivery } from '../../lib/image';
import { stitchImages } from '../../lib/stitch-images';

interface Props {
  badge: string;
  heading: string;
  subheading: string;
  quote: string;
  primaryCtaLabel: string;
  primaryCtaUrl: string;
  secondaryCtaLabel: string;
  secondaryCtaUrl: string;
  image?: ImageDelivery;
  imageAlt?: string;
}

const {
  badge,
  heading,
  subheading,
  quote,
  primaryCtaLabel,
  primaryCtaUrl,
  secondaryCtaLabel,
  secondaryCtaUrl,
  image,
  imageAlt = 'Ρυθμική γυμναστική',
} = Astro.props;

const heroImage = image ?? { src: stitchImages.hero };
---

<section class="ribbon-bg relative flex min-h-[85vh] items-center overflow-hidden">
  <div class="absolute inset-0 z-0">
    <div class="absolute inset-0 z-10 bg-gradient-to-r from-background via-background/40 to-transparent"></div>
    <PlaceholderImage
      delivery={heroImage}
      alt={imageAlt}
      loading="eager"
      fetchPriority="high"
      decoding="sync"
      class="h-full w-full scale-105 object-cover object-center"
    />
  </div>

  <div class="container-page relative z-20 py-section-padding">
    <div class="max-w-2xl">
      <span class="mb-6 inline-block rounded-full bg-primary-container px-4 py-1.5 font-display text-label-md uppercase tracking-wider text-on-primary-container">
        {badge}
      </span>
      <h1 class="mb-4 font-display text-display-lg text-on-surface">{heading}</h1>
      <p class="mb-8 font-display text-headline-md text-primary">{subheading}</p>
      <blockquote class="mb-10 border-l-4 border-primary pl-6 font-body text-body-lg italic text-on-surface-variant">
        "{quote}"
      </blockquote>
      <div class="flex flex-wrap gap-4">
        <Button href={primaryCtaUrl} variant="primary" size="lg">{primaryCtaLabel}</Button>
        <Button href={secondaryCtaUrl} variant="secondary" size="lg">{secondaryCtaLabel}</Button>
      </div>
    </div>
  </div>

  <div class="absolute bottom-0 left-0 w-full overflow-hidden leading-none" aria-hidden="true">
    <svg class="relative block h-24 w-full" preserveAspectRatio="none" viewBox="0 0 1200 120">
      <path class="fill-surface" d="M321.39,56.44c58-10.79,114.16-30.13,172-41.86,82.39-16.72,168.19-17.73,250.45-.39C823.78,31,906.67,72,985.66,92.83c70.05,18.48,146.53,26.09,214.34,3V120H0V95.8C58.47,105,123.82,108,187,97.77,235.39,89.92,279.16,70.52,321.39,56.44Z"></path>
    </svg>
  </div>
</section>
