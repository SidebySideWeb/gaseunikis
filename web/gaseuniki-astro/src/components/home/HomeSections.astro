---
import SectionHeader from '../ui/SectionHeader.astro';

interface Props {
  heading: string;
}

const { heading } = Astro.props;

const rhythmicMass = ['Νήπια (3-5 ετών)', 'Ακαδημίες (4-6 ετών)', 'Προχωρημένα (6-10)', 'Εφηβικό (12-16)'];
const gymnTeams = ['Team 1 (Elite)', 'Team 2 (Junior)', 'Team 3 (Development)'];
---

<section class="ribbon-bg py-section-padding">
  <div class="container-page">
    <SectionHeader heading={heading} align="center" />

    <div class="mt-16 grid gap-gutter md:grid-cols-2">
      <article class="glass-card hover-lift shadow-card rounded-[2rem] border-t-4 border-primary p-10">
        <header class="mb-8 flex items-start justify-between">
          <div>
            <h3 class="mb-2 font-display text-headline-lg text-primary">Ρυθμική Γυμναστική</h3>
            <p class="text-on-surface-variant">Η τέχνη της κίνησης, της μουσικής και των οργάνων.</p>
          </div>
          <span class="material-symbols-outlined text-5xl text-primary opacity-30" aria-hidden="true">sports_gymnastics</span>
        </header>
        <div class="mb-10 space-y-6">
          <div>
            <h4 class="mb-3 font-display text-label-md uppercase tracking-wider text-secondary">Αγωνιστικά Τμήματα</h4>
            <ul class="grid grid-cols-2 gap-2 font-body text-body-md">
              <li class="flex items-center gap-2"><span class="h-1.5 w-1.5 rounded-full bg-primary"></span> Ηλικίες 8-15</li>
              <li class="flex items-center gap-2"><span class="h-1.5 w-1.5 rounded-full bg-primary"></span> Ηλικίες 6-8</li>
            </ul>
          </div>
          <div>
            <h4 class="mb-3 font-display text-label-md uppercase tracking-wider text-secondary">Τμήματα Μαζικού Αθλητισμού</h4>
            <ul class="grid grid-cols-2 gap-3 font-body text-body-md">
              {rhythmicMass.map((item) => (
                <li class="rounded-lg border border-primary/10 bg-primary/5 p-2">{item}</li>
              ))}
            </ul>
          </div>
        </div>
        <a href="/tmimata" class="inline-flex items-center gap-2 font-bold text-primary hover:underline">
          Μάθετε Περισσότερα <span class="material-symbols-outlined" aria-hidden="true">arrow_forward</span>
        </a>
      </article>

      <article class="glass-card hover-lift shadow-card rounded-[2rem] border-t-4 border-secondary p-10">
        <header class="mb-8 flex items-start justify-between">
          <div>
            <h3 class="mb-2 font-display text-headline-lg text-secondary">Γυμναστική για Όλους</h3>
            <p class="text-on-surface-variant">Ομαδικότητα, θέαμα και χαρά της συμμετοχής.</p>
          </div>
          <span class="material-symbols-outlined text-5xl text-secondary opacity-30" aria-hidden="true">groups</span>
        </header>
        <div class="mb-10">
          <h4 class="mb-3 font-display text-label-md uppercase tracking-wider text-primary">Αγωνιστικές Ομάδες Contest</h4>
          <ul class="grid gap-4">
            {gymnTeams.map((team) => (
              <li class="flex items-center justify-between rounded-xl border border-secondary/20 bg-secondary/10 p-4">
                <span class="font-bold text-on-surface">{team}</span>
                <span class="material-symbols-outlined text-primary" aria-hidden="true">workspace_premium</span>
              </li>
            ))}
          </ul>
        </div>
        <a href="/tmimata" class="inline-flex items-center gap-2 font-bold text-secondary hover:underline">
          Μάθετε Περισσότερα <span class="material-symbols-outlined" aria-hidden="true">arrow_forward</span>
        </a>
      </article>
    </div>
  </div>
</section>
