---
import SectionHeader from '../ui/SectionHeader.astro';
import type { Program } from '../../lib/types';

interface Props {
  heading: string;
  ctaLabel: string;
  ctaUrl: string;
  rhythmicHeading: string;
  rhythmicDescription: string;
  rhythmicCategoryHeading: string;
  rhythmicCompetitive: Program[];
  rhythmicMassHeading: string;
  rhythmicMass: Program[];
  gymnHeading: string;
  gymnDescription: string;
  gymSections: Program[];
}

const {
  heading,
  ctaLabel,
  ctaUrl,
  rhythmicHeading,
  rhythmicDescription,
  rhythmicCategoryHeading,
  rhythmicCompetitive,
  rhythmicMassHeading,
  rhythmicMass,
  gymnHeading,
  gymnDescription,
  gymSections,
} = Astro.props;
---

<section class="ribbon-bg py-section-padding">
  <div class="container-page">
    <SectionHeader heading={heading} align="center" />

    <div class="mt-16 grid gap-gutter md:grid-cols-2">
      <article class="glass-card hover-lift shadow-card rounded-[2rem] border-t-4 border-primary p-10">
        <header class="mb-8 flex items-start justify-between">
          <div>
            <h3 class="mb-2 font-display text-headline-lg text-primary-text">{rhythmicHeading}</h3>
            <p class="text-on-surface-variant">{rhythmicDescription}</p>
          </div>
          <span class="material-symbols-outlined text-5xl text-primary opacity-30" aria-hidden="true">sports_gymnastics</span>
        </header>
        <div class="mb-10 space-y-6">
          {rhythmicCompetitive.length > 0 && (
            <div>
              <h4 class="mb-3 font-display text-label-md uppercase tracking-wider text-secondary-text">{rhythmicCategoryHeading}</h4>
              <ul class="grid grid-cols-2 gap-2 font-body text-body-md">
                {rhythmicCompetitive.map((item) => (
                  <li class="flex items-center gap-2">
                    <span class="h-1.5 w-1.5 rounded-full bg-primary"></span>
                    {item.ageRange ? `Ηλικίες ${item.ageRange}` : item.name}
                  </li>
                ))}
              </ul>
            </div>
          )}
          {rhythmicMass.length > 0 && (
            <div>
              <h4 class="mb-3 font-display text-label-md uppercase tracking-wider text-secondary-text">{rhythmicMassHeading}</h4>
              <ul class="grid grid-cols-2 gap-3 font-body text-body-md">
                {rhythmicMass.map((item) => (
                  <li class="rounded-lg border border-primary/10 bg-primary/5 p-2">{item.name}</li>
                ))}
              </ul>
            </div>
          )}
        </div>
        <a
          href={ctaUrl}
          class="inline-flex items-center gap-2 font-bold text-primary-text hover:underline"
          aria-label={`${ctaLabel} — ${rhythmicHeading}`}
        >
          {ctaLabel} <span class="material-symbols-outlined" aria-hidden="true">arrow_forward</span>
        </a>
      </article>

      <article class="glass-card hover-lift shadow-card rounded-[2rem] border-t-4 border-secondary p-10">
        <header class="mb-8 flex items-start justify-between">
          <div>
            <h3 class="mb-2 font-display text-headline-lg text-secondary-text">{gymnHeading}</h3>
            <p class="text-on-surface-variant">{gymnDescription}</p>
          </div>
          <span class="material-symbols-outlined text-5xl text-secondary opacity-30" aria-hidden="true">groups</span>
        </header>
        <div class="mb-10">
          <h4 class="mb-3 font-display text-label-md uppercase tracking-wider text-primary-text">Αγωνιστικές Ομάδες Contest</h4>
          <ul class="grid gap-4">
            {gymSections.map((team) => (
              <li class="flex items-center justify-between rounded-xl border border-secondary/20 bg-secondary/10 p-4">
                <span class="font-bold text-on-surface">{team.name}</span>
                <span class="material-symbols-outlined text-primary" aria-hidden="true">workspace_premium</span>
              </li>
            ))}
          </ul>
        </div>
        <a
          href={ctaUrl}
          class="inline-flex items-center gap-2 font-bold text-secondary-text hover:underline"
          aria-label={`${ctaLabel} — ${gymnHeading}`}
        >
          {ctaLabel} <span class="material-symbols-outlined" aria-hidden="true">arrow_forward</span>
        </a>
      </article>
    </div>
  </div>
</section>
