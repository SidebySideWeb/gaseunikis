---
import AchievementCardGallery from '../successes/AchievementCardGallery.astro';
import Button from '../ui/Button.astro';
import SectionHeader from '../ui/SectionHeader.astro';
import type { Achievement, Stat } from '../../lib/types';
import {
  buildAchievementGalleryImages,
  formatAchievementYears,
  resolveAchievementYears,
} from '../../lib/achievement-display';

interface Props {
  heading: string;
  subheading: string;
  items: Achievement[];
  stats: Stat[];
  ctaLabel: string;
  ctaUrl: string;
}

const { heading, subheading, items, stats, ctaLabel, ctaUrl } = Astro.props;
---

<section class="relative overflow-hidden bg-surface-container-low py-section-padding">
  <span class="material-symbols-outlined pointer-events-none absolute right-0 top-1/2 -translate-y-1/2 text-[400px] text-primary opacity-10" aria-hidden="true">
    emoji_events
  </span>

  <div class="container-page relative z-10">
    <SectionHeader heading={heading} subtext={subheading} align="center" />

    <div class="mb-12 grid gap-8 md:grid-cols-3">
      {items.map((item, index) => {
        const galleryImages = buildAchievementGalleryImages(item, index);
        const yearsLabel = formatAchievementYears(resolveAchievementYears(item));

        return (
          <article class="group flex flex-col overflow-hidden rounded-2xl border border-achievement/20 bg-surface-container-lowest shadow-card">
            <AchievementCardGallery
              galleryId={item._id}
              images={galleryImages}
              yearsLabel={yearsLabel}
              priority={index === 0}
            />
            <div class="flex grow flex-col p-4 md:p-5">
              <h3 class="font-display text-body-md font-semibold leading-snug text-on-surface line-clamp-4">
                {item.title}
              </h3>
            </div>
          </article>
        );
      })}
    </div>

    <div class="mb-12 flex flex-col items-center justify-center gap-12 md:flex-row">
      {stats.map((stat) => (
        <div class="text-center">
          <span class="mb-2 block text-5xl font-bold text-primary">{stat.value}</span>
          <span class="font-display text-label-md uppercase tracking-wider text-on-surface-variant">{stat.label}</span>
        </div>
      ))}
    </div>

    <div class="text-center">
      <Button href={ctaUrl} variant="primary" size="lg">{ctaLabel}</Button>
    </div>
  </div>
</section>
