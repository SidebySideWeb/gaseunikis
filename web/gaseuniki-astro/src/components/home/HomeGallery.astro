---
import PlaceholderImage from '../ui/PlaceholderImage.astro';
import type { GalleryImage } from '../../lib/types';
import { getGalleryFallback } from '../../lib/stitch-images';
import { resolveImageUrl } from '../../lib/image';

interface Props {
  heading: string;
  subheading: string;
  items: GalleryImage[];
}

const { heading, subheading, items } = Astro.props;
---

<section class="bg-on-surface py-section-padding text-surface">
  <div class="container-page">
    <header class="mb-12">
      <h2 class="mb-2 font-display text-headline-lg">{heading}</h2>
      <p class="text-surface/70">{subheading}</p>
    </header>

    <div class="grid gap-8 md:grid-cols-3">
      {items.map((item, index) => (
        <figure class="group relative h-[400px] overflow-hidden rounded-2xl ring-1 ring-primary/20">
          <PlaceholderImage
            src={resolveImageUrl(item.image, getGalleryFallback(index))}
            alt={item.image?.alt ?? item.caption ?? 'Στιγμή προπόνησης'}
            class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-110"
          />
          <figcaption class="absolute inset-0 flex items-end bg-gradient-to-t from-black/90 via-black/20 to-transparent p-8">
            <h3 class="border-l-4 border-primary pl-4 font-display text-headline-md text-white">{item.caption}</h3>
          </figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>
