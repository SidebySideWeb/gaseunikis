---
import RecaptchaWidget from '../ui/RecaptchaWidget.astro';

interface Props {
  formHeading: string;
  formSubmitLabel: string;
  subjectOptions: string[];
}

const { formHeading, formSubmitLabel, subjectOptions } = Astro.props;

const inputClass =
  'w-full bg-surface-container-low border-none rounded-xl focus:ring-2 focus:ring-primary py-4 px-5 transition-all outline-none';
---

<div class="lg:col-span-7">
  <div class="bg-surface-container-lowest p-8 md:p-10 rounded-2xl shadow-2xl relative border-t-4 border-primary">
    <div class="absolute top-0 right-0 p-8" aria-hidden="true">
      <span class="material-symbols-outlined text-primary/20 text-6xl animate-float">edit_square</span>
    </div>
    <h2 class="font-display text-headline-lg text-on-surface mb-8">{formHeading}</h2>

    <div
      id="contact-form-success"
      class="mb-6 hidden rounded-xl border border-green-200 bg-green-50 p-4 text-green-800"
      role="status"
    >
      Ευχαριστούμε για το μήνυμα! Θα επικοινωνήσουμε σύντομα μαζί σας.
    </div>

    <div
      id="contact-form-error"
      class="mb-6 hidden rounded-xl border border-error/20 bg-error-container p-4 text-on-error-container"
      role="alert"
    ></div>

    <form id="contact-form" class="space-y-6" novalidate>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="space-y-2">
          <label class="block font-label-md text-on-surface-variant" for="fullName">Ονοματεπώνυμο</label>
          <input
            id="fullName"
            name="fullName"
            type="text"
            required
            class={inputClass}
            placeholder="Π.χ. Ιωάννα Παπαδοπούλου"
          />
        </div>
        <div class="space-y-2">
          <label class="block font-label-md text-on-surface-variant" for="email">Email</label>
          <input
            id="email"
            name="email"
            type="email"
            required
            class={inputClass}
            placeholder="example@mail.com"
          />
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="space-y-2">
          <label class="block font-label-md text-on-surface-variant" for="phone">Τηλέφωνο</label>
          <input id="phone" name="phone" type="tel" required class={inputClass} placeholder="69x xxxxxxx" />
        </div>
        <div class="space-y-2">
          <label class="block font-label-md text-on-surface-variant" for="subject">Θέμα</label>
          <select id="subject" name="subject" class={inputClass}>
            {subjectOptions.map((option) => (
              <option value={option}>{option}</option>
            ))}
          </select>
        </div>
      </div>

      <div class="space-y-2">
        <label class="block font-label-md text-on-surface-variant" for="message">Το Μήνυμά σας</label>
        <textarea
          id="message"
          name="message"
          rows={5}
          required
          class={`${inputClass} resize-none`}
          placeholder="Πώς μπορούμε να σας βοηθήσουμε;"
        ></textarea>
      </div>

      <RecaptchaWidget widgetKey="contact" />

      <button
        type="submit"
        id="contact-form-submit"
        class="group flex w-full items-center justify-center gap-2 rounded-xl bg-primary py-4 font-display text-label-md text-on-primary shadow-card transition-all duration-200 hover:bg-primary-light hover:shadow-card-hover disabled:cursor-not-allowed disabled:opacity-60"
      >
        <span id="contact-form-submit-label">{formSubmitLabel}</span>
        <span id="contact-form-submit-icon" class="material-symbols-outlined transition-transform group-hover:translate-x-1">
          send
        </span>
        <span id="contact-form-submit-spinner" class="material-symbols-outlined hidden animate-spin">sync</span>
      </button>
    </form>
  </div>
</div>

<script>
  import { getRecaptchaResponse, resetRecaptcha } from '../../lib/recaptcha-client';

  const form = document.getElementById('contact-form');
  if (form instanceof HTMLFormElement) {
    const successEl = document.getElementById('contact-form-success');
    const errorEl = document.getElementById('contact-form-error');
    const submitBtn = document.getElementById('contact-form-submit');
    const submitLabel = document.getElementById('contact-form-submit-label');
    const submitIcon = document.getElementById('contact-form-submit-icon');
    const submitSpinner = document.getElementById('contact-form-submit-spinner');

    function setSubmitting(isSubmitting: boolean) {
      submitBtn?.toggleAttribute('disabled', isSubmitting);
      submitLabel?.classList.toggle('hidden', isSubmitting);
      submitIcon?.classList.toggle('hidden', isSubmitting);
      submitSpinner?.classList.toggle('hidden', !isSubmitting);
    }

    function showError(message: string) {
      successEl?.classList.add('hidden');
      if (errorEl) {
        errorEl.textContent = message;
        errorEl.classList.remove('hidden');
      }
    }

    form.addEventListener('submit', async (event) => {
      event.preventDefault();
      errorEl?.classList.add('hidden');

      const data = new FormData(form);
      const fullName = String(data.get('fullName') ?? '').trim();
      const email = String(data.get('email') ?? '').trim();
      const phone = String(data.get('phone') ?? '').trim();
      const subject = String(data.get('subject') ?? '').trim();
      const message = String(data.get('message') ?? '').trim();

      if (!fullName || !email || !phone || !message) {
        showError('Συμπληρώστε όλα τα υποχρεωτικά πεδία.');
        return;
      }

      const recaptchaToken = getRecaptchaResponse('contact');
      if (!recaptchaToken) {
        showError('Επιβεβαιώστε ότι δεν είστε ρομπότ.');
        return;
      }

      setSubmitting(true);

      try {
        const response = await fetch('/api/contact', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ fullName, email, phone, subject, message, recaptchaToken }),
        });

        if (!response.ok) {
          const payload = (await response.json().catch(() => null)) as { error?: string } | null;
          throw new Error(payload?.error ?? 'Η αποστολή απέτυχε. Δοκιμάστε ξανά.');
        }

        successEl?.classList.remove('hidden');
        form.reset();
        resetRecaptcha('contact');
      } catch (error) {
        showError(error instanceof Error ? error.message : 'Η αποστολή απέτυχε. Δοκιμάστε ξανά.');
        resetRecaptcha('contact');
      } finally {
        setSubmitting(false);
      }
    });
  }
</script>
