---
interface Props {
  heading: string;
  text: string;
  callToAction: string;
}

const { heading, text, callToAction } = Astro.props;
---

<section class="py-16 md:py-24 px-gutter max-w-container-max-width mx-auto">
  <div class="text-center max-w-3xl mx-auto">
    <span class="inline-block px-4 py-1.5 mb-6 rounded-full bg-secondary-container text-on-secondary-container font-label-md uppercase tracking-wider text-xs">
      {callToAction}
    </span>
    <h1 class="font-display text-display-lg text-primary mb-6">{heading}</h1>
    <p class="font-body text-body-lg text-on-surface-variant leading-relaxed">{text}</p>
  </div>
</section>
