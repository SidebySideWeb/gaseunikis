---
interface Props {
  historyHeading: string;
  historyText: string;
  recognitionText: string;
  accreditationText: string;
}

const { historyHeading, historyText, recognitionText, accreditationText } = Astro.props;

const historyCardText =
  'Χρόνια επιτυχημένης πορείας με συμμετοχές σε πανελλήνια πρωταθλήματα και διεθνείς διοργανώσεις.';
---

<section class="bg-surface-container-lowest pb-24 pt-12">
  <div class="container-page">
    <div class="flex flex-col gap-gutter md:flex-row">
      <header class="md:w-1/3">
        <h2 class="mb-4 font-display text-headline-md text-primary">Σχετικά με εμάς</h2>
        <div class="mb-6 h-1 w-16 rounded-full bg-primary-container"></div>
      </header>

      <div class="space-y-6 md:w-2/3">
        <p class="font-body text-body-lg text-on-surface-variant">{historyText}</p>
        <div class="grid gap-stack-md sm:grid-cols-2">
          <article class="rounded-xl border-l-4 border-primary bg-surface-container-low p-6 shadow-card">
            <h3 class="mb-2 font-display text-headline-md text-primary">{historyHeading}</h3>
            <p class="text-on-surface-variant">{historyCardText}</p>
          </article>
          <article class="rounded-xl border-l-4 border-secondary bg-surface-container-low p-6 shadow-card">
            <h3 class="mb-2 font-display text-headline-md text-primary">{recognitionText}</h3>
            <p class="text-on-surface-variant">{accreditationText}</p>
          </article>
        </div>
      </div>
    </div>
  </div>
</section>
