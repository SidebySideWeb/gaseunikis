---
import PlaceholderImage from '../ui/PlaceholderImage.astro';
import type { ValueCard } from '../../lib/types';
import { stitchImages } from '../../lib/stitch-images';

interface Props {
  heading: string;
  items: ValueCard[];
  primaryImageUrl?: string;
  secondaryImageUrl?: string;
  primaryImageAlt?: string;
  secondaryImageAlt?: string;
}

const {
  heading,
  items,
  primaryImageUrl = stitchImages.philosophyFacility,
  secondaryImageUrl = stitchImages.philosophyTraining,
  primaryImageAlt = 'Σύγχρονες εγκαταστάσεις γυμναστικής',
  secondaryImageAlt = 'Νεαρές αθλήτριες σε προπόνηση',
} = Astro.props;

const iconColors = ['bg-primary-dark text-on-primary', 'bg-secondary text-on-secondary', 'bg-primary-dark text-on-primary'];
---

<section class="bg-surface-container-low py-24">
  <div class="container-page grid grid-cols-1 items-center gap-stack-lg md:grid-cols-2">
    <div class="order-2 md:order-1">
      <div class="grid grid-cols-2 gap-4">
        <PlaceholderImage
          src={primaryImageUrl}
          alt={primaryImageAlt}
          class="aspect-square rounded-lg border-2 border-primary/10 object-cover shadow-card"
        />
        <PlaceholderImage
          src={secondaryImageUrl}
          alt={secondaryImageAlt}
          class="mt-8 aspect-square rounded-lg border-2 border-secondary/10 object-cover shadow-card"
        />
      </div>
    </div>

    <div class="order-1 md:order-2">
      <h2 class="mb-6 font-display text-headline-md text-primary">{heading}</h2>
      <ul class="space-y-8">
        {items.map((item, index) => (
          <li class="flex gap-4">
            <div class={`flex h-12 w-12 shrink-0 items-center justify-center rounded-full ${iconColors[index % iconColors.length]}`}>
              <span class="material-symbols-outlined" aria-hidden="true">{item.icon ?? 'verified'}</span>
            </div>
            <div>
              <h3 class="mb-1 font-bold text-primary">{item.title}</h3>
              <p class="text-on-surface-variant">{item.description}</p>
            </div>
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>
