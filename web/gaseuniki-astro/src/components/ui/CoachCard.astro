---
import PlaceholderImage from '../ui/PlaceholderImage.astro';
import type { Coach } from '../../lib/types';
import { coachFallbacks } from '../../lib/stitch-images';
import { resolveImageUrl } from '../../lib/image';

export interface Props {
  coach: Coach;
  index: number;
  variant?: 'compact' | 'detailed';
}

const { coach, index, variant = 'compact' } = Astro.props;
const photoUrl = resolveImageUrl(coach.photo, coachFallbacks[index % coachFallbacks.length]);
---

{
  variant === 'detailed' ? (
    <article class="overflow-hidden rounded-2xl border border-primary/10 bg-surface-container-lowest shadow-card">
      <div class="flex flex-col md:flex-row">
        <div class="relative shrink-0 md:w-64 lg:w-72">
          <PlaceholderImage
            src={photoUrl}
            alt={coach.photo?.alt ?? coach.name}
            class="h-56 w-full object-cover md:h-full md:min-h-[22rem]"
          />
        </div>
        <div class="flex flex-1 flex-col p-6 text-left md:p-8">
          <header class="mb-4">
            <h3 class="font-display text-headline-md text-primary">{coach.name}</h3>
            {coach.role && (
              <p class="mt-1 text-xs font-bold uppercase tracking-wider text-secondary">{coach.role}</p>
            )}
          </header>

          {coach.bio && (
            <div class="mb-6 flex-1">
              <h4 class="mb-2 font-display text-label-md uppercase tracking-wider text-on-surface-variant">
                Βιογραφικό
              </h4>
              <p class="whitespace-pre-line font-body text-body-md leading-relaxed text-on-surface-variant">
                {coach.bio}
              </p>
            </div>
          )}

          {coach.certifications && (
            <footer class="mt-auto border-t border-primary/10 pt-4">
              <h4 class="mb-2 font-display text-label-md text-primary">Πιστοποιήσεις</h4>
              <p class="font-body text-body-md leading-relaxed text-on-surface-variant">
                {coach.certifications}
              </p>
            </footer>
          )}
        </div>
      </div>
    </article>
  ) : (
    <article class="flex flex-col items-center rounded-xl border border-primary/10 bg-surface-container-lowest p-6 text-center shadow-card">
      <div class="mb-6 h-32 w-32 overflow-hidden rounded-full border-2 border-primary-container">
        <PlaceholderImage
          src={photoUrl}
          alt={coach.photo?.alt ?? coach.name}
          class="h-full w-full object-cover"
        />
      </div>
      <h3 class="mb-1 font-display text-headline-md text-primary">{coach.name}</h3>
      {coach.role && (
        <p class="mb-4 text-xs font-bold uppercase tracking-wider text-secondary">{coach.role}</p>
      )}
      {coach.bio && <p class="mb-4 text-sm text-on-surface-variant">{coach.bio}</p>}
      {coach.certifications && (
        <footer class="mt-auto w-full border-t border-primary/10 pt-4">
          <p class="text-xs font-bold text-primary">Πιστοποιήσεις:</p>
          <p class="text-xs text-on-surface-variant">{coach.certifications}</p>
        </footer>
      )}
    </article>
  )
}
