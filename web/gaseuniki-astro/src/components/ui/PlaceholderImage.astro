---
import type { ImageDelivery } from '../../lib/image';

export interface Props {
  alt: string;
  src?: string;
  delivery?: ImageDelivery;
  aspectRatio?: 'video' | 'square' | 'portrait' | 'wide';
  class?: string;
  loading?: 'lazy' | 'eager';
  fetchPriority?: 'high' | 'low' | 'auto';
  decoding?: 'async' | 'sync' | 'auto';
}

const {
  alt,
  src,
  delivery,
  aspectRatio = 'video',
  class: className = '',
  loading = 'lazy',
  fetchPriority,
  decoding = 'async',
} = Astro.props;

const imageSrc = delivery?.src ?? src;
const srcSet = delivery?.srcSet;
const sizes = delivery?.sizes;

const aspectClasses = {
  video: 'aspect-video',
  square: 'aspect-square',
  portrait: 'aspect-[3/4]',
  wide: 'aspect-[21/9]',
};
---

{
  imageSrc ? (
    <img
      src={imageSrc}
      srcset={srcSet}
      sizes={sizes}
      alt={alt}
      loading={loading}
      decoding={decoding}
      fetchpriority={fetchPriority}
      class:list={[aspectClasses[aspectRatio], className]}
    />
  ) : (
    <div
      class:list={[
        'flex items-center justify-center rounded-lg bg-surface-container text-on-surface-variant',
        aspectClasses[aspectRatio],
        className,
      ]}
      role="img"
      aria-label={alt}
    >
      <span class="px-4 text-center font-body text-body-md opacity-70">{alt}</span>
    </div>
  )
}
