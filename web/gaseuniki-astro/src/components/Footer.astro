---
import ClubLogoMark from './ClubLogoMark.astro';
import { buildFooterUsefulLinks } from '../lib/fallbacks';
import { dedupeNavCtaFromLinks, resolveNavCta, resolveNavLinks } from '../lib/nav-links';
import { getImageUrl, IMAGE_PRESETS } from '../lib/image';
import type { SiteSettings } from '../lib/types';

export interface Props {
  settings: SiteSettings;
}

const { settings } = Astro.props;

const clubName = settings?.clubName ?? 'ΓΑΣ ΕΥΝΙΚΗ';
const logoUrl = getImageUrl(settings?.logo, IMAGE_PRESETS.logoFooter) ?? '/favicon.png';
const logoAlt = settings?.logo?.alt ?? `${clubName} Logo`;
const tagline =
  settings?.footerTagline ??
  'Προωθούμε τον αθλητισμό και τις αξίες του μέσα από τη ρυθμική γυμναστική στην Ελευσίνα.';
const copyright =
  settings?.footerCopyright ??
  '© 2024 Γας Ευνίκη Ελευσίνας. Με την επιφύλαξη παντός δικαιώματος.';
const navCta = resolveNavCta(settings);
const navigationLinks = dedupeNavCtaFromLinks(resolveNavLinks(settings), navCta);
const usefulLinks = buildFooterUsefulLinks(settings);
---

<footer class="mt-auto border-t border-outline-variant/30 bg-surface-container-highest">
  <div class="container-page grid grid-cols-1 gap-gutter py-section-padding md:grid-cols-4">
    <div class="space-y-4">
      <div class="flex items-center gap-3">
        <ClubLogoMark size="sm" src={logoUrl} alt={logoAlt} />
        <span class="font-display text-headline-md font-bold text-on-surface">{clubName}</span>
      </div>
      <p class="font-body text-body-md text-on-surface-variant">{tagline}</p>
    </div>

    <div class="grid grid-cols-2 gap-x-gutter gap-y-6 md:contents">
      <div>
        <h2 class="mb-4 font-display text-label-md uppercase tracking-wider text-primary">Πλοήγηση</h2>
        <ul class="space-y-2">
          {
            navigationLinks.map((link) => (
              <li>
                <a
                  href={link.url}
                  class="font-body text-body-md text-on-surface-variant transition-colors hover:text-secondary"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div>
        <h2 class="mb-4 font-display text-label-md uppercase tracking-wider text-primary">Χρήσιμα</h2>
        <ul class="space-y-2">
          {
            usefulLinks.map((link) => (
              <li>
                <a
                  href={link.url}
                  class="font-body text-body-md text-on-surface-variant transition-colors hover:text-secondary"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div class="col-span-2 flex flex-col items-end md:col-span-1 md:items-start">
        <h2 class="mb-4 font-display text-label-md uppercase tracking-wider text-primary text-right md:text-left">
          Ακολουθήστε μας
        </h2>
        <div class="flex justify-end gap-4 md:justify-start">
          {
            settings?.facebookUrl && (
              <a
                href={settings.facebookUrl}
                class="flex h-10 w-10 items-center justify-center rounded-full bg-primary/10 text-primary transition-all hover:bg-primary hover:text-on-primary"
                aria-label="Facebook"
                target="_blank"
                rel="noopener noreferrer"
              >
                <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" />
                </svg>
              </a>
            )
          }
          {
            settings?.instagramUrl && (
              <a
                href={settings.instagramUrl}
                class="flex h-10 w-10 items-center justify-center rounded-full bg-primary/10 text-primary transition-all hover:bg-primary hover:text-on-primary"
                aria-label="Instagram"
                target="_blank"
                rel="noopener noreferrer"
              >
                <span class="material-symbols-outlined">photo_camera</span>
              </a>
            )
          }
        </div>
      </div>
    </div>
  </div>

  <div class="border-t border-outline-variant/20 py-8">
    <p class="text-center font-body text-body-md text-on-surface-variant">{copyright}</p>
  </div>
</footer>
