---
import type { RegistrationStep } from '../../lib/types';

interface Props {
  steps: RegistrationStep[];
}

const { steps } = Astro.props;
---

<section class="bg-white p-8 rounded-2xl shadow-sm border border-surface-container-highest">
  <h2 class="font-display text-headline-md mb-6 flex items-center gap-3">
    <span class="material-symbols-outlined text-primary">assignment_add</span>
    Βήματα Εγγραφής
  </h2>
  <div class="space-y-6">
    {steps.map((step, index) => (
      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 rounded-full bg-primary/10 text-primary flex items-center justify-center font-bold">
          {index + 1}
        </div>
        <div>
          <h4 class="font-bold text-on-surface">{step.title}</h4>
          {step.description && <p class="text-sm text-on-surface-variant">{step.description}</p>}
        </div>
      </div>
    ))}
  </div>
</section>
