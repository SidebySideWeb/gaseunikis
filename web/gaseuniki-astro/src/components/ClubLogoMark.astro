---
interface Props {
  size?: 'sm' | 'md';
  src?: string;
  alt?: string;
}

const { size = 'md', src, alt = 'Logo' } = Astro.props;

const sizeClasses =
  size === 'sm' ? 'h-[62px] w-[62px]' : 'h-[62px] w-[62px] md:h-[74px] md:w-[74px]';
const iconClasses = size === 'sm' ? 'text-4xl' : 'text-4xl md:text-5xl';
const pixelSize = size === 'sm' ? 62 : 74;
---

{
  src ? (
    <img
      src={src}
      alt={alt}
      class:list={['shrink-0 object-contain', sizeClasses]}
      width={pixelSize}
      height={pixelSize}
    />
  ) : (
    <span
      class:list={[
        'flex shrink-0 items-center justify-center rounded-xl bg-primary/10 text-primary',
        sizeClasses,
      ]}
      aria-hidden="true"
    >
      <span class:list={['material-symbols-outlined', iconClasses]}>sports_gymnastics</span>
    </span>
  )
}
