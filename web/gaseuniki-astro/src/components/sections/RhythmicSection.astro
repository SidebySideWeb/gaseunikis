---
import PlaceholderImage from '../ui/PlaceholderImage.astro';
import type { Program } from '../../lib/types';
import { stitchImages } from '../../lib/stitch-images';

interface Props {
  heading: string;
  description: string;
  categoryHeading: string;
  competitive: Program[];
  massHeading: string;
  mass: Program[];
  imageUrl?: string;
  imageAlt?: string;
}

const {
  heading,
  description,
  categoryHeading,
  competitive,
  massHeading,
  mass,
  imageUrl = stitchImages.rhythmicGymnast,
  imageAlt = 'Αθλήτρια ρυθμικής γυμναστικής με κορδέλα',
} = Astro.props;
---

<section class="mb-section-padding px-gutter">
  <div class="max-w-container-max-width mx-auto">
    <div class="flex flex-col md:flex-row gap-12 items-center mb-16">
      <div class="w-full md:w-1/2">
        <div class="relative">
          <div class="absolute -top-4 -left-4 w-24 h-24 bg-primary-light/30 rounded-full opacity-40 -z-10" aria-hidden="true"></div>
          <PlaceholderImage
            src={imageUrl}
            alt={imageAlt}
            class="w-full aspect-[4/3] rounded-3xl shadow-xl ring-4 ring-primary/5"
          />
        </div>
      </div>
      <div class="w-full md:w-1/2">
        <div class="inline-flex items-center gap-2 text-primary font-bold mb-4">
          <span class="material-symbols-outlined">sports_gymnastics</span>
          <span class="uppercase tracking-widest text-xs">Πρόγραμμα</span>
        </div>
        <h2 class="font-display text-headline-lg mb-6 text-on-surface">{heading}</h2>
        <p class="text-body-lg text-on-surface-variant leading-relaxed">{description}</p>
      </div>
    </div>

    <div class="mb-16">
      <div class="flex items-center gap-4 mb-8">
        <h3 class="font-display text-headline-md text-secondary">{categoryHeading}</h3>
        <div class="h-0.5 flex-grow bg-primary/10" aria-hidden="true"></div>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-10">
        {competitive.map((card, index) => (
          <article class={`bg-surface p-8 rounded-3xl border-t-4 ${index === 0 ? 'border-primary' : 'border-secondary'} shadow-sm hover:shadow-md transition-shadow relative overflow-hidden group`}>
            <div class={`absolute top-0 right-0 w-24 h-24 ${index === 0 ? 'bg-primary/5' : 'bg-secondary/5'} rounded-full -mr-12 -mt-12 transition-transform group-hover:scale-150`} aria-hidden="true"></div>
            <div class="flex justify-between items-start mb-4 relative z-10">
              <h3 class="font-display text-headline-md">{card.name}</h3>
              {card.badge && (
                <span class={`${index === 0 ? 'bg-primary/10 text-primary' : 'bg-secondary-container/20 text-secondary'} px-3 py-1 rounded-full text-xs font-bold`}>
                  {card.badge}
                </span>
              )}
            </div>
            <p class="text-on-surface-variant mb-6 relative z-10">{card.description}</p>
            {card.schedule && (
              <div class="space-y-2 border-t border-outline-variant pt-4 relative z-10">
                <div class={`text-xs font-bold ${index === 0 ? 'text-primary' : 'text-secondary'} uppercase tracking-wider`}>Πρόγραμμα</div>
                <div class="flex items-center gap-2 text-on-surface font-semibold">
                  <span class={`material-symbols-outlined ${index === 0 ? 'text-primary' : 'text-secondary'} text-sm`}>calendar_month</span>
                  <span>{card.schedule}</span>
                </div>
              </div>
            )}
          </article>
        ))}
      </div>
    </div>

    <div class="mb-16">
      <div class="flex items-center gap-4 mb-8">
        <h3 class="font-display text-headline-md text-primary">{massHeading}</h3>
        <div class="h-0.5 flex-grow bg-primary/10" aria-hidden="true"></div>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {mass.map((card, index) => {
          const isGradient = index === 2;
          const isSecondary = index === 1;
          return (
            <article class={
              isGradient
                ? 'gradient-primary text-on-primary p-6 rounded-3xl shadow-card'
                : isSecondary
                  ? 'bg-white p-6 rounded-3xl border-2 border-primary/10 hover:border-secondary/40 transition-all'
                  : 'bg-surface-container-low p-6 rounded-3xl flex flex-col justify-between border-2 border-transparent hover:border-primary/20 hover:bg-white transition-all'
            }>
              <div>
                <h3 class={`font-display text-headline-md mb-2 ${isSecondary ? 'text-secondary' : isGradient ? '' : 'text-primary'}`}>{card.name}</h3>
                <p class={`mb-4 ${isGradient ? 'opacity-90' : 'text-on-surface-variant'}`}>{card.description}</p>
              </div>
              {card.schedule && (
                <div class={`space-y-2 border-t pt-4 ${isGradient ? 'border-white/20' : isSecondary ? 'border-secondary/10' : 'border-primary/10'}`}>
                  <div class={`text-[10px] font-bold uppercase tracking-widest ${isGradient ? 'opacity-70' : isSecondary ? 'text-secondary' : 'text-primary'}`}>Πρόγραμμα</div>
                  <div class="text-sm font-bold flex items-center gap-2">
                    <span class={`w-1.5 h-1.5 rounded-full ${isGradient ? 'bg-white' : isSecondary ? 'bg-secondary' : 'bg-primary'}`} aria-hidden="true"></span>
                    {card.schedule}
                  </div>
                </div>
              )}
            </article>
          );
        })}
      </div>
    </div>
  </div>
</section>
