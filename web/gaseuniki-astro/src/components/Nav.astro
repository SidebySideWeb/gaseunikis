---
import NavMobile from './NavMobile.astro';import Button from './ui/Button.astro';
import ClubLogoMark from './ClubLogoMark.astro';
import { dedupeNavCtaFromLinks, resolveNavCta, resolveNavLinks } from '../lib/nav-links';
import { getImageUrl, IMAGE_PRESETS } from '../lib/image';
import type { SiteSettings } from '../lib/types';

export interface Props {
  currentPath: string;
  settings: SiteSettings;
}

const { currentPath, settings } = Astro.props;

const navCta = resolveNavCta(settings);
const navLinks = dedupeNavCtaFromLinks(resolveNavLinks(settings), navCta);
const navCtaLabel = navCta.label;
const navCtaUrl = navCta.url;
const clubName = settings?.clubName ?? 'ΓΑΣ ΕΥΝΙΚΗ';
const logoUrl = getImageUrl(settings?.logo, IMAGE_PRESETS.logoNav) ?? '/favicon.png';
const logoAlt = settings?.logo?.alt ?? `${clubName} Logo`;

function isActive(url: string): boolean {
  if (url === '/') return currentPath === '/';
  return currentPath === url || currentPath.startsWith(`${url}/`);
}
---

<header class="fixed top-0 left-0 right-0 z-50 border-b border-primary/5 bg-surface-container-lowest shadow-sm">
  <nav
    class="container-page flex items-center justify-between py-4"
    aria-label="Κύρια πλοήγηση"
  >
    <a href="/" class="flex items-center gap-3">
      <ClubLogoMark src={logoUrl} alt={logoAlt} />
      <span class="font-display text-headline-md font-bold text-primary">{clubName}</span>
    </a>

    <div class="hidden items-center gap-4 font-display text-label-md md:flex lg:gap-8">
      {
        navLinks.map((link) => (
          <a
            href={link.url}
            class:list={[
              'transition-colors',
              isActive(link.url)
                ? 'border-b-2 border-primary pb-1 text-primary'
                : 'text-on-surface-variant hover:text-primary',
            ]}
            aria-current={isActive(link.url) ? 'page' : undefined}
          >
            {link.label}
          </a>
        ))
      }
    </div>

    <div class="flex items-center gap-4">
      <Button href={navCtaUrl} variant="primary" size="sm" class="hidden md:inline-flex">
        {navCtaLabel}
      </Button>

      <NavMobile
        links={navLinks}
        ctaLabel={navCtaLabel}
        ctaUrl={navCtaUrl}
        currentPath={currentPath}
        clubName={clubName}
      />
    </div>
  </nav>
</header>
